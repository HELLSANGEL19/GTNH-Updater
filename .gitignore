# Runtime directories (created by the script)
cache/
logs/
backups/
.temp/
.nightly-updater/
staging-*/

# User config (contains local paths)
gtnh-updater-config.json
gtnh-config-export.json
gtnh-patches-export.json

# Broken config backups
gtnh-updater-config.broken-*.json

# Lock file (prevents concurrent runs)
.updater.lock
